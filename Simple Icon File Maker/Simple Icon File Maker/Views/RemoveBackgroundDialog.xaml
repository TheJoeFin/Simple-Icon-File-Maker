<ContentDialog
    x:Class="Simple_Icon_File_Maker.RemoveBackgroundDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Remove Background"
    CloseButtonText="Cancel"
    IsPrimaryButtonEnabled="False"
    Loaded="ContentDialog_Loaded"
    PrimaryButtonText="Apply"
    mc:Ignorable="d">

    <Grid MinWidth="480" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock
            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
            Text="Extract the main object from the image using on-device AI"
            TextWrapping="Wrap" />

        <Grid Grid.Row="1" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="8">
                <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}" Text="Before" />
                <Border
                    MinHeight="200"
                    Padding="8"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="4">
                    <Image
                        x:Name="BeforeImage"
                        MaxHeight="250"
                        Stretch="Uniform" />
                </Border>
            </StackPanel>

            <StackPanel Grid.Column="1" Spacing="8">
                <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}" Text="After" />
                <Border
                    MinHeight="200"
                    Padding="8"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="4">
                    <Grid>
                        <Image
                            x:Name="AfterImage"
                            MaxHeight="250"
                            Stretch="Uniform" />
                        <ProgressRing
                            x:Name="ProcessingRing"
                            Width="32"
                            Height="32"
                            IsActive="True" />
                    </Grid>
                </Border>
            </StackPanel>
        </Grid>

        <InfoBar
            x:Name="StatusInfoBar"
            Grid.Row="2"
            IsClosable="False"
            IsOpen="False" />
    </Grid>
</ContentDialog>