<ContentDialog
    x:Class="Simple_Icon_File_Maker.PreCheckDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Simple_Icon_File_Maker.Models"
    Title="Large Folder Detected"
    CloseButtonText="Cancel"
    Loaded="ContentDialog_Loaded"
    PrimaryButtonClick="ContentDialog_PrimaryButtonClick"
    PrimaryButtonStyle="{StaticResource AccentButtonStyle}"
    PrimaryButtonText="Process Files"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Margin="12,20" Spacing="16">

            <TextBlock
                x:Name="SummaryTextBlock"
                Style="{StaticResource BodyTextBlockStyle}"
                TextWrapping="WrapWholeWords" />

            <TextBlock Style="{StaticResource SubtitleTextBlockStyle}">
                File groups found:
            </TextBlock>

            <ListView
                ItemsSource="{x:Bind FileGroups}"
                SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:FileGroupItem">
                        <CheckBox
                            Content="{x:Bind DisplayLabel}"
                            IsChecked="{x:Bind IsIncluded, Mode=TwoWay}" />
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <CheckBox
                x:Name="DontShowAgainCheckBox"
                Content="Don't show this confirmation again" />

        </StackPanel>
    </ScrollViewer>
</ContentDialog>
